# ============================================================================
# auto/config.env  — fill this in, then: cp config.env.example config.env
# Every value below is something that CANNOT be inferred from the repo.
# ============================================================================

# ---- absolute paths on the server ----
export REPO_ROOT=/data/tokenskip_submission        # where this repo lives on the server
export DATA_ROOT=/data/tokenskip_artifacts         # big disk: merged models + sweep outputs
export HF_HOME=/data/hf_cache                       # HuggingFace download cache
export MODELS_DIR=/data/models                       # base models downloaded here (pinned commits)

# ---- HuggingFace ----
export HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # needed for gated Llama-3.1 + downloads

# ---- pinned base-model commit SHAs (exact reproduction) ----
export QWEN3B_SHA=PUT_QWEN3B_COMMIT_SHA_HERE
export QWEN7B_SHA=PUT_QWEN7B_COMMIT_SHA_HERE
export QWEN14B_SHA=PUT_QWEN14B_COMMIT_SHA_HERE
export LLAMA8B_SHA=PUT_LLAMA8B_COMMIT_SHA_HERE

# ---- energy / PDU ----
export ENABLE_PDU=1                                  # 1 = log PDU energy via SNMP, 0 = GPU energy only
export PDU_IP=192.0.2.1                              # <-- your real rack PDU SNMP host
export PDU_SNMP_COMMUNITY=public
export PDU_OID="PowerNet-MIB::ePDUPhaseStatusActivePower.1"

# ---- McEval Docker image (already pinned to the repo digest; leave as-is) ----
export MCEVAL_DIGEST=sha256:4735da5db683f96aef4b3d849881fa7ddf865a480ce55287f0019b4f377c52a5

# ============================================================================
# Knobs you usually leave alone
# ============================================================================
export TS_ENV=tokenskip_env                          # conda env: inference/compression/merge/score
export LF_ENV=llamafactory_env                        # conda env: LoRA SFT
export LLMLINGUA_CKPT=microsoft/llmlingua-2-xlm-roberta-large-meetingbank

# Decoding (greedy; do not change for reproduction)
export SEED=42
export TEMPERATURE=0.0

# Measured-sweep grid (paper defaults). Shrink for a smoke test, e.g.:
#   export SWEEP_TOKENS="256"; export SWEEP_RATIOS="1.0 0.7"; export SWEEP_REPEATS=1
# Per-benchmark BASE max_new_tokens (evaluation.py auto-scales by gamma for gamma<1.0).
# These match the reference budgets; override individually if needed.
export TOK_GSM8K=512
export TOK_MATH=1024
export TOK_BOOLQ=1024
export TOK_PIQA=512
export TOK_MCEVAL=1024
export SWEEP_TOKENS="512"          # fallback for any bench not in the map above
export SWEEP_RATIOS="1.0 0.9 0.8 0.7 0.6 0.5 0.4 0.3 0.2 0.1"
export SWEEP_REPEATS=3

# mceval-specific: gamma grid (default drops 0.95/0.85 from the 12-point grid), run id,
# and (for 8B/Llama, not on HF) the existing server merge to reuse.
export MCEVAL_GAMMAS="1.0 0.9 0.8 0.7 0.6 0.5 0.4 0.3 0.2 0.1"
export MCEVAL_RUN_ID=hubrepro
# export MCEVAL_8B_MERGED=/home/bd510854/training_llama_8.1/tokenskip_mceval3/tokenskip_mceval3/weights/llama-3.1-8b-instruct/merged_sft_run01
export MONITOR_INTERVAL=0.5

# Baseline train-gen budget (data generation, NOT energy-measured)
export TRAINGEN_MAX_NEW_TOKENS=512
export EVAL_BATCH_SIZE=16

# Which models / benchmarks to process (space-separated keys).
# model keys: qwen2.5-3b qwen2.5-7b qwen2.5-14b llama3.1-8b
export MODELS_TO_RUN="qwen2.5-3b qwen2.5-7b qwen2.5-14b llama3.1-8b"
export BENCHMARKS_TO_RUN="gsm8k math boolq piqa"

# Set DRY_RUN=1 to print commands without executing the heavy steps.
export DRY_RUN=0

# ============================================================================
# HuggingFace adapter upload (auto/upload_adapters.sh) + fast repro
# ============================================================================
export HF_NAMESPACE=your-hf-username-or-org           # repos created under this namespace
export HF_REPO_PREFIX=tokenskip                       # repo = <ns>/<prefix>-qwen2.5-<size>
export HF_PRIVATE=1                                   # 1 = private repos, 0 = public

# Source roots on the SERVER (defaults match the trees you showed).
export LORA_SAVES_DIR=/home/bd510854/training_llama_8.1/LlamaFactory/lora_saves
export MCEVAL_WEIGHTS_DIR=/home/bd510854/training_llama_8.1/tokenskip_mceval3/tokenskip_mceval3/weights

# Which Qwen sizes to publish, and which benches.
export PUBLISH_SIZES="3b 7b 14b"
export PUBLISH_BENCHES="boolq gsm8k math piqa mceval"
